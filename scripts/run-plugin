#!/usr/bin/env python3
"""Run a plugin CLI. Usage: ./scripts/run-plugin <plugin-name> [args...]

Examples:
    ./scripts/run-plugin coingecko trending
    ./scripts/run-plugin allium sql "SELECT 1"
    ./scripts/run-plugin linear issues --team ENG
    ./scripts/run-plugin defillama stablecoins
"""

import importlib.util
import sys
import types
from pathlib import Path

if len(sys.argv) < 2:
    print(__doc__)
    sys.exit(1)

plugin_name = sys.argv[1]
plugin_dir = Path(__file__).resolve().parent.parent / "plugins" / plugin_name

if not plugin_dir.exists():
    available = sorted(
        d.name for d in (Path(__file__).resolve().parent.parent / "plugins").iterdir()
        if d.is_dir() and not d.name.startswith((".", "_"))
    )
    print(f"Plugin '{plugin_name}' not found. Available: {', '.join(available)}")
    sys.exit(1)

# Register plugin dir as a package so relative imports work
pkg_name = plugin_name
pkg = types.ModuleType(pkg_name)
pkg.__path__ = [str(plugin_dir)]
pkg.__package__ = pkg_name
sys.modules[pkg_name] = pkg

# Load and run the CLI
cli_path = plugin_dir / "cli.py"
spec = importlib.util.spec_from_file_location(f"{pkg_name}.cli", cli_path)
cli_mod = importlib.util.module_from_spec(spec)
cli_mod.__package__ = pkg_name
sys.modules[f"{pkg_name}.cli"] = cli_mod
spec.loader.exec_module(cli_mod)

sys.argv = [f"{plugin_name}-plugin"] + sys.argv[2:]
cli_mod.app()
