{
  "name": "@centaur/cli",
  "version": "0.1.0",
  "description": "Agent-readable onboarding CLI for Centaur deployments",
  "license": "Apache-2.0 OR MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "centaur": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "centaur": "tsx src/index.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "incur": "^0.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
