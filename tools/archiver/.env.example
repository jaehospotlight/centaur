# Database connection string (PostgreSQL with pgvector)
PARCHIVER_DATABASE_URL=postgresql://user:pass@localhost:5432/parchiver

# Embedding dimensions (default: 3072 for DB schema, 1024 for search/embed)
PARCHIVER_EMBEDDING_DIMS=1024

# OpenRouter API key for embedding generation and search
PARCHIVER_OPENROUTER_API_KEY=

# Reducto API key for document parsing/extraction
PARCHIVER_REDUCTO_API_KEY=

# Reducto job timeouts (seconds)
PARCHIVER_PARSE_TIMEOUT_S=300
PARCHIVER_EXTRACT_TIMEOUT_S=300

# Reducto extract optimization (true/false)
PARCHIVER_EXTRACT_OPTIMIZE_FOR_LATENCY=true

# Cloudflare R2 storage for archiving
PARCHIVER_R2_ENDPOINT_URL=
PARCHIVER_R2_ACCESS_KEY_ID=
PARCHIVER_R2_SECRET_ACCESS_KEY=
PARCHIVER_R2_BUCKET=paradigm-ai-archive
PARCHIVER_R2_PREFIX=prod-v0

# Browser-Use cloud API key for DocSend scraping
PARCHIVER_BROWSER_USE_API_KEY=

# Browser-Use proxy country code (e.g. "us")
PARCHIVER_BROWSER_USE_PROXY_COUNTRY=

# Browser-Use persistent profile ID
PARCHIVER_BROWSER_USE_PROFILE_ID=

# DocSend debug directory (save screenshots/HTML for debugging)
PARCHIVER_DOCSEND_DEBUG_DIR=

# Telemetry / logging
PARCHIVER_LOG_LEVEL=INFO
PARCHIVER_LOG_FORMAT=json
PARCHIVER_RUN_ID=
PARCHIVER_STREAM_TEE=true
PARCHIVER_STREAM_DIR=logs/parchiver
PARCHIVER_STDOUT_LOG=
PARCHIVER_STDERR_LOG=
