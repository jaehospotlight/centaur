<% content_for :title, "Threads · Centaur Console" %>

<% if @thread_db_unavailable %>
  <div class="mb-4 shrink-0 rounded border border-amber-500/30 bg-amber-500/[0.08] px-4 py-3 text-sm text-amber-200">
    Thread database is unavailable. Set <span class="font-semibold">CENTAUR_CONSOLE_CENTAUR_DATABASE_URL</span>
    so Console can read the API session database.
  </div>
<% end %>

<div class="flex min-h-0 flex-1 overflow-hidden bg-ink-950/15">
  <section class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden bg-ink-900/25">
    <div class="console-thread-detail-header">
      <div class="console-thread-content">
        <% if @selected_session %>
          <% selected_thread_title = thread_title(@selected_session) %>
          <% thread_meta = capture do %>
            <div class="flex min-w-0 items-center gap-2">
              <span class="truncate"><%= thread_source_label(@selected_session) %></span>
              <span>·</span>
              <span><%= thread_harness_label(@selected_session) %></span>
              <span>·</span>
              <%= local_time(@selected_session.updated_at || @selected_session.created_at, relative: true, format: :compact) %>
            </div>
          <% end %>

          <%= render "console/page_header",
                     title: selected_thread_title,
                     title_attr: selected_thread_title,
                     subtitle: thread_meta,
                     title_class: "truncate text-base font-semibold text-zinc-100",
                     subtitle_class: "mt-0.5 text-xs text-zinc-500",
                     class: "mb-0 min-h-16 items-center" %>
        <% else %>
          <%= render "console/page_header",
                     title: "New thread",
                     subtitle: @threads_read_only ? "Select a mirrored thread from the sidebar." : "Start from the composer below.",
                     title_class: "text-base font-semibold text-zinc-100",
                     subtitle_class: "mt-0.5 text-xs text-zinc-500",
                     class: "mb-0 min-h-16 items-center" %>
        <% end %>
      </div>
    </div>

    <div id="thread-transcript-scroll" class="min-h-0 flex-1 overflow-y-auto py-6">
      <% if @selected_session %>
        <div class="console-thread-content flex flex-col gap-6">
          <% if @selected_transcript_items.empty? %>
            <div class="rounded-xl border border-dashed border-ink-800/80 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">
              No messages have been persisted for this thread yet.
            </div>
          <% end %>

          <% @selected_transcript_items.each do |item| %>
            <% user_message = item[:align] == :end %>
            <div class="group flex <%= user_message ? "justify-end" : "justify-start" %>">
              <div class="console-message-stack flex flex-col <%= user_message ? "max-w-[72%] items-end" : "w-full max-w-3xl items-start" %>">
                <div class="<%= user_message ? "w-full rounded-[24px] bg-ink-700 px-4 py-3 text-zinc-100" : "w-full text-zinc-300" %>">
                  <% unless user_message %>
                    <div class="mb-1 text-xs font-medium text-zinc-500"><%= item[:label] || item[:role] %></div>
                  <% end %>
                  <div class="console-markdown text-sm leading-6"><%= console_markdown(item[:text].presence || "No text content.") %></div>
                </div>
                <div class="console-message-timestamp <%= "text-right" if user_message %>">
                  <%= local_time(item[:created_at]) if item[:created_at] %>
                </div>
              </div>
            </div>
          <% end %>

        </div>
      <% else %>
        <div class="flex h-full items-center justify-center text-sm text-zinc-600">
          <% if @sessions.empty? %>
            No threads yet.
          <% elsif @threads_read_only %>
            Select a thread from the sidebar.
          <% else %>
            Start a new thread from the composer below.
          <% end %>
        </div>
      <% end %>
    </div>

    <% unless @threads_read_only %>
      <div class="bg-ink-950/35 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
        <%= form_with url: console_threads_path, method: :post, class: "console-thread-content" do %>
          <% if @selected_session %>
            <input type="hidden" name="thread_key" value="<%= @selected_session.thread_key %>">
            <input type="hidden" name="harness_type" value="<%= @selected_session.harness_type %>">
          <% end %>

          <div class="rounded-[30px] bg-ink-800 px-5 py-4 shadow-2xl shadow-black/20 ring-1 ring-white/[0.04] transition-shadow focus-within:ring-centaur-500/35">
            <textarea name="prompt"
                      rows="2"
                      class="min-h-12 w-full resize-none bg-transparent text-[15px] leading-6 text-zinc-100 placeholder-zinc-500 focus:outline-none"
                      placeholder="<%= @selected_session ? "Message this thread" : "Start a new Centaur thread" %>"></textarea>
            <div class="mt-3 flex items-center gap-3 border-t border-white/[0.05] pt-3">
              <% if !@selected_session %>
                <label class="text-xs uppercase tracking-wider text-zinc-500" for="harness_type">Harness</label>
                <select id="harness_type" name="harness_type"
                        class="rounded-lg border border-white/[0.08] bg-ink-850 px-2.5 py-1.5 text-sm text-zinc-200 focus:border-centaur-500/70 focus:outline-none focus:ring-1 focus:ring-centaur-500/40">
                  <option value="codex">codex</option>
                  <option value="amp">amp</option>
                  <option value="claudecode">claude-code</option>
                </select>
              <% else %>
                <div class="truncate text-xs text-zinc-500">
                  <%= @selected_session.harness_type %> · <%= @selected_session.thread_key %>
                </div>
              <% end %>
              <div class="flex-1"></div>
              <button type="submit"
                      class="inline-grid size-10 place-items-center rounded-full bg-zinc-100 text-ink-950 transition-colors hover:bg-centaur-300"
                      title="<%= @selected_session ? "Send message" : "Start thread" %>"
                      aria-label="<%= @selected_session ? "Send message" : "Start thread" %>">
                <%= console_icon("arrow-up", classes: "size-5") %>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
</div>

<script>
  (() => {
    const scrollThreadTranscript = () => {
      const transcript = document.getElementById("thread-transcript-scroll");
      if (!transcript) return;

      window.requestAnimationFrame(() => {
        transcript.scrollTop = transcript.scrollHeight;
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", scrollThreadTranscript, { once: true });
    } else {
      scrollThreadTranscript();
    }
  })();
</script>
